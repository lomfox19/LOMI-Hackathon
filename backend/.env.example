# Production: set in your hosting dashboard (Render, Railway, etc.)
PORT=5000
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
GROQ_API_KEY=your_groq_api_key

# Frontend URL for CORS (production: your Vercel/Netlify URL)
# Optional: comma-separated list for multiple origins
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Auth (keep from your existing .env)
JWT_SECRET=your-jwt-secret
JWT_EXPIRE=7d
# Email, reCAPTCHA, Google OAuth as needed
